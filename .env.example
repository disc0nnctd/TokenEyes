# ── Vision backends (at least one required for image analysis) ──────────────

# Gemini API key (free tier available)
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-key-here

# OpenRouter API key (free models available: gemini-2.0-flash, llama-4-scout, qwen2-vl)
# Get one at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# NVIDIA NIM API key (free API trial + free endpoints available)
# Get one at: https://build.nvidia.com/
NVIDIA_API_KEY=your-nvidia-api-key-here

# Cloudflare Workers AI (free tier included with any CF account)
# API token: https://dash.cloudflare.com/profile/api-tokens (needs Workers AI:Read permission)
# Account ID: https://dash.cloudflare.com → right sidebar on any zone
CLOUDFLARE_ACCOUNT_ID=your-account-id-here
CLOUDFLARE_WORKERS_API_KEY=your-workers-ai-token-here

# Proxy mode (Cloudflare Pages runtime /proxy in cloudflare/_worker.js)
# Shared password clients must provide when using "Shared key" mode in the UI
PROXY_PASSWORD=choose-a-strong-shared-password

# Optional Cloudflare AI REST fallback used by /proxy (separate from Workers AI vars above)
CF_ACCOUNT_ID=your-account-id-here
CF_API_TOKEN=your-cloudflare-api-token-here
