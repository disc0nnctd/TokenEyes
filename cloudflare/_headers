/*
  # Prevent the page from being embedded in iframes elsewhere
  X-Frame-Options: SAMEORIGIN
  # Block sniffing content type
  X-Content-Type-Options: nosniff
  # Referrer: send origin only so API key doesn't leak in Referer headers
  Referrer-Policy: strict-origin-when-cross-origin
  # Permissions: camera yes (needed), everything else off
  Permissions-Policy: camera=(*), microphone=(), geolocation=(), payment=()
  # Content Security Policy:
  #   - default: self
  #   - connect: allow Gemini + OpenRouter + Cloudflare Workers AI plus custom HTTPS endpoints
  #   - img-src: allow blob: and data: for captured frames
  #   - no unsafe-eval, no unsafe-inline scripts (app is one inline script block, needed)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; connect-src 'self' https://generativelanguage.googleapis.com https://openrouter.ai https://api.cloudflare.com https:; frame-ancestors 'none';
